<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<title>WaferLens-Sherlock — FA Triage Report</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; margin: 40px auto; max-width: 920px; color: #1a202c; }
  h1 { border-bottom: 2px solid #444; padding-bottom: 6px; }
  h2 { color: #2a4365; margin-top: 26px; }
  .meta { color: #555; font-size: 0.9em; }
  img { max-width: 100%; border: 1px solid #e2e8f0; border-radius: 6px; }
  table.t { border-collapse: collapse; width: 100%; margin: 10px 0; font-size: 0.92em; }
  table.t th, table.t td { border: 1px solid #e2e8f0; padding: 6px 10px; text-align: left; }
  table.t thead { background: #edf2f7; }
  .bar { background: #4299e1; height: 14px; border-radius: 3px; }
  .card { background: #f7fafc; border-left: 4px solid #3182ce; padding: 10px 14px; margin: 10px 0; }
  .hint { background: #fffaf0; border-left: 4px solid #dd6b20; padding: 8px 12px; margin: 8px 0; font-size: 0.9em; }
  .none { background: #f0fff4; border-left: 4px solid #38a169; padding: 10px 14px; }
  ul { margin: 4px 0; } footer { margin-top: 36px; color: #777; font-size: 0.8em; border-top: 1px solid #e2e8f0; padding-top: 10px; }
</style>
</head>
<body>
<h1>WaferLens-Sherlock — FA Triage Report</h1>
<p class="meta">Sample: <b>{{ sample_id }}</b> &middot; Generated: {{ generated }}</p>

<h2>Wafer map & model evidence</h2>
<img src="{{ wafer_png }}" alt="wafer map" />

<h2>Predicted defect patterns</h2>
<table class="t">
  <thead><tr><th>Defect type</th><th>Probability</th><th></th></tr></thead>
  <tbody>
  {% for name, p in ranked_probs %}
    <tr>
      <td>{{ name }}{% if name in detected %} <b>(detected)</b>{% endif %}</td>
      <td>{{ "%.3f"|format(p) }}</td>
      <td style="width:40%"><div class="bar" style="width: {{ (p*100)|round(0)|int }}%"></div></td>
    </tr>
  {% endfor %}
  </tbody>
</table>

<h2>Failure-analysis triage</h2>
{% if not triage.entries %}
<div class="none">{{ triage.summary }}</div>
{% else %}
<p>{{ triage.summary }}</p>
{% for e in triage.entries %}
<div class="card">
  <b>{{ e.pattern }}</b> &middot; <span class="meta">typical area: {{ e.typical_process_area }}</span>
  <p style="margin:6px 0 2px"><b>Candidate root causes</b></p>
  <ul>{% for c in e.candidate_causes %}<li>{{ c }}</li>{% endfor %}</ul>
  <p style="margin:6px 0 2px"><b>Recommended checks</b></p>
  <ul>{% for c in e.recommended_checks %}<li>{{ c }}</li>{% endfor %}</ul>
</div>
{% endfor %}
{% for h in triage.compound_hints %}
<div class="hint"><b>Compound hint:</b> {{ h }}</div>
{% endfor %}
{% endif %}

<div class="hint">
These are <b>candidate hypotheses</b> derived from the wafer-map spatial signature, for a
human FA engineer to confirm. They are not a final diagnosis.
</div>

<footer>WaferLens-Sherlock v0.1.0 &middot; defect classification (CNN + ViT) + rule-based FA triage.</footer>
</body>
</html>
